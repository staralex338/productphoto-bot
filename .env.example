# ============================================
# Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-app.up.railway.app/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Database Configuration (Supabase)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=product-images

# ============================================
# AI Providers
# ============================================
FAL_KEY=your_fal_ai_key_here
REPLICATE_API_TOKEN=your_replicate_token_here
REMOVE_BG_API_KEY=your_remove_bg_key_here
CLIPDROP_API_KEY=your_clipdrop_key_here

# ============================================
# Payment Providers
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
TELEGRAM_PAYMENT_PROVIDER_TOKEN=your_telegram_provider_token

# ============================================
# Application Settings
# ============================================
APP_NAME=ProductPhoto AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Free credits for new users
FREE_CREDITS_ON_START=3
REFERRAL_BONUS_INVITER=10
REFERRAL_BONUS_INVITED=5

# Generation settings
MAX_IMAGE_SIZE_MB=10
MIN_IMAGE_DIMENSION=512
DEFAULT_GENERATIONS_COUNT=4
STORAGE_TTL_DAYS=30
DAILY_GENERATION_LIMIT=50

# Queue settings
MAX_CONCURRENT_GENERATIONS=5
GENERATION_TIMEOUT_SECONDS=120
